# ── Auth ──────────────────────────────────────────────
# API key required to access all /api/* endpoints
API_KEY=demo

# ── AI Provider ──────────────────────────────────────
# Required — powers all agent and generation endpoints
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Default model used when no model is specified in requests
# DEFAULT_MODEL=openai/gpt-4o-mini

# Server port
# PORT=3000

# ── Voice (TTS / STT) ───────────────────────────────
# At least one key required for voice features
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Groq (fast transcription via whisper-large-v3-turbo): https://console.groq.com/keys
GROQ_API_KEY=

VOICE_PROVIDER=openai
VOICE_TTS_MODEL=tts-1
VOICE_STT_MODEL=gpt-4o-mini-transcribe
VOICE_DEFAULT_SPEAKER=alloy
VOICE_RETAIN_AUDIO=false

# ── Tool API Keys ───────────────────────────────────
# TMDB — needed for the Knowledge Base (movie) agent demo
# Get one at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Brave Search — needed for the web-search tool
# Get one at https://brave.com/search/api/
BRAVE_API_KEY=
